# Artha Root Environment Variables
# These are used by docker-compose.yml for global configuration

# -----------------------------
# Shared infrastructure settings
# -----------------------------
EUREKA_SERVER_URL=http://service-registry:8761/eureka/
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKER=kafka:29092
KAFKA_GROUP_ID=notification-service-group
KAFKA_COMPANY_GROUP_ID=notification-service-company-group
ANALYSIS_EXPENSE_GROUP_ID=analysis-expense-group
ANALYSIS_BUDGET_GROUP_ID=analysis-budget-group
# -----------------------------
# User service (PostgreSQL)
# -----------------------------
USER_DB_URL=<USER_SERVICE_JDBC_URL>
USER_DB_USERNAME=<USER_SERVICE_DB_USERNAME>
USER_DB_PASSWORD=<USER_SERVICE_DB_PASSWORD>

# -----------------------------
# Budget service (PostgreSQL)
# -----------------------------
BUDGET_DB_URL=<BUDGET_SERVICE_JDBC_URL>
BUDGET_DB_USERNAME=<BUDGET_SERVICE_DB_USERNAME>
BUDGET_DB_PASSWORD=<BUDGET_SERVICE_DB_PASSWORD>

# -----------------------------
# Expense service (PostgreSQL)
# -----------------------------
EXPENSE_DB_URL=<EXPENSE_SERVICE_JDBC_URL>
EXPENSE_DB_USERNAME=<EXPENSE_SERVICE_DB_USERNAME>
EXPENSE_DB_PASSWORD=<EXPENSE_SERVICE_DB_PASSWORD>

# -----------------------------
# Auth and OAuth2
# -----------------------------
JWT_SECRET=<STRONG_RANDOM_SECRET>
GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_OAUTH_CLIENT_SECRET>

# -----------------------------
# Analysis and Notification services
# -----------------------------
MONGO_DETAILS=<ANALYSIS_MONGO_URL>
MONGODB_URI=<NOTIFICATION_MONGO_URL>

SENDGRID_API_KEY=<YOUR_SENDGRID_API_KEY>
FROM_EMAIL=<YOUR_EMAIL>

# -----------------------------
# Frontend build-time config
# -----------------------------
VITE_API_BASE_URL=http://localhost:8080

# -----------------------------
# CORS Configuration
# -----------------------------
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------
# Distributed Deployment
# -----------------------------
# Set this to your laptop's actual IP address (e.g. 192.168.1.10)
SERVER_IP=localhost
