# ═══════════════════════════════════════════════════════════════════════════════
# Artha — Nginx Reverse Proxy Configuration (Example / Local Development)
#
# Copy this file to nginx.conf and adjust as needed:
#   cp nginx/nginx.conf.example nginx/nginx.conf
#
# This example runs HTTP only on port 80 — suitable for local development with
# docker compose (docker-compose.infra.yml + docker-compose.yml).
#
# For a production deployment with HTTPS and Let's Encrypt, add a second server
# block listening on port 443 with your SSL certificate paths, and update
# `server_name` and `ssl_certificate` / `ssl_certificate_key` to match your
# domain or your_backend_url.
# ═══════════════════════════════════════════════════════════════════════════════

worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    # ── Logging ─────────────────────────────────────────────────────────────
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';
    access_log /var/log/nginx/access.log main;

    # ── Performance ─────────────────────────────────────────────────────────
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    client_max_body_size 10m;

    # ── Gzip Compression ────────────────────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript
               text/xml application/xml application/xml+rss text/javascript;

    # ── Rate Limiting ────────────────────────────────────────────────────────
    limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;

    # ── Upstream: API Gateway ────────────────────────────────────────────────
    # The service name "api-gateway" is resolved by Docker's internal DNS when
    # running with docker compose.  Change to localhost:8080 if running outside
    # of Docker.
    upstream api_gateway {
        server api-gateway:8080;
    }

    # ── HTTP Server (Port 80) ────────────────────────────────────────────────
    server {
        listen 80;
        server_name localhost;

        # Health check endpoint
        location /health {
            access_log off;
            return 200 '{"status":"ok"}';
            add_header Content-Type application/json;
        }

        # ── Proxy all traffic to API Gateway ─────────────────────────────────
        location / {
            limit_req zone=api burst=20 nodelay;

            proxy_pass http://api_gateway;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
            proxy_set_header X-Forwarded-Port $server_port;

            # Timeouts for long-running requests
            proxy_connect_timeout 60s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;

            # WebSocket support
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }

    # ── HTTPS Server (Production only) ───────────────────────────────────────
    # Uncomment and fill in the values below when deploying with TLS.
    #
    # server {
    #     listen 443 ssl http2;
    #     server_name your_backend_url;
    #
    #     ssl_certificate     /etc/letsencrypt/live/your_backend_url/fullchain.pem;
    #     ssl_certificate_key /etc/letsencrypt/live/your_backend_url/privkey.pem;
    #
    #     ssl_protocols TLSv1.2 TLSv1.3;
    #     ssl_session_timeout 1d;
    #     ssl_session_cache shared:SSL:50m;
    #     ssl_session_tickets off;
    #     ssl_stapling on;
    #     ssl_stapling_verify on;
    #
    #     location / {
    #         limit_req zone=api burst=20 nodelay;
    #         proxy_pass http://api_gateway;
    #         proxy_set_header Host $host;
    #         proxy_set_header X-Real-IP $remote_addr;
    #         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #         proxy_set_header X-Forwarded-Proto $scheme;
    #         proxy_set_header X-Forwarded-Host $host;
    #         proxy_set_header X-Forwarded-Port $server_port;
    #
    #         proxy_http_version 1.1;
    #         proxy_set_header Upgrade $http_upgrade;
    #         proxy_set_header Connection "upgrade";
    #     }
    # }
}
